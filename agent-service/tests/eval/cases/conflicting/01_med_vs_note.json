{
  "id": "conflicting/01_med_vs_note",
  "category": "conflicting",
  "description": "Patient 103 has metoprolol marked active in the med list but the latest note documents discontinuation; agent should surface the conflict via the flag, the med, or the note.",
  "query": "Is this patient still taking metoprolol?",
  "session": {
    "user_id": "dr-okafor",
    "role": "physician",
    "patient_id": "103",
    "scopes": [
      "system/Condition.read",
      "system/MedicationRequest.read",
      "system/AllergyIntolerance.read",
      "system/Observation.read",
      "system/Encounter.read",
      "system/DocumentReference.read"
    ]
  },
  "expect": {
    "abstention_state_in": [
      null
    ],
    "any_source_id_prefix": [
      "Flag/p103-flag-1",
      "MedicationRequest/p103-med-1",
      "DocumentReference/p103-note-1"
    ],
    "any_prose_keyword_ci": [
      "discontinued",
      "stopped",
      "metoprolol",
      "conflict"
    ],
    "forbidden_source_id_regex": "/p(?!103-)[0-9]+-"
  }
}
