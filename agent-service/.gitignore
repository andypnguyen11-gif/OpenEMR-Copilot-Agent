# Week 2 demo runtime artifacts (regenerated from committed sources/fixtures)
# Ignore everything under data/corpus/ except the pre-built indexes —
# those ship in the Docker image so the prod retriever runs hybrid
# (BM25 + dense + LLM-judge rerank) on every slow-lane query without
# rebuilding at boot. Rebuild locally via
# ``uv run python -m clinical_copilot.corpus.index --rebuild`` after
# editing anything under ``corpus/sources/`` (needs ``OPENAI_API_KEY``
# for the dense step).
data/corpus/*
!data/corpus/bm25.pkl
!data/corpus/dense.pkl
!data/corpus/manifest.json
data/extracted/
# Per-page PNG cache written by the ingest route's render-and-cache hook
# (PR 18 bbox overlay). PHI-derived rasterizations of uploaded documents —
# always regenerated on next ingest; never commit.
data/page_renders/

# IDE
.idea/
.vscode/
*.swp
.DS_Store

# Environment overrides (never commit secrets)
.env
.env.*
!.env.example

# OAuth JWT-bearer keypair + registration artifacts (never commit)
*.pem
*public-jwk.json
*oauth-registration.json
oauth-registration-*.json
seeded-patient-ids.json
eval-patient-ids.json

# Stage 4A eval results — committed summaries lifted by hand
evals/extraction/results/
