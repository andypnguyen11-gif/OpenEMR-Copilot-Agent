# Copy to .env.local and fill in.
# Vite exposes only variables prefixed with VITE_ to the browser.

# OpenEMR base URL — OAuth + FHIR endpoints live under here.
# Local dev (default): https://localhost:9300
VITE_OPENEMR_BASE_URL=https://localhost:9300

# OAuth2 public client ID. Register one in OpenEMR:
#   Admin → System → API Clients → Register New Client
#   - Application Type: Public
#   - Redirect URI: http://localhost:5173/callback
#   - Scopes: openid, offline_access, launch/patient, patient/*.read
# Paste the client_id below after registering.
VITE_OAUTH_CLIENT_ID=

# Optional. FHIR base URL the SPA fetches from. Defaults to /apis/default/fhir
# (relative — served via Vite's proxy in dev to avoid the cross-origin
# preflight that OpenEMR's CORSListener fails). Set this to an absolute URL
# only in prod where the SPA host has CORS configured at OpenEMR.
# VITE_FHIR_BASE_URL=https://openemr.example.com/apis/default/fhir
